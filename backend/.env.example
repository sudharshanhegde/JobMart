# ── Server ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────
# Local MongoDB (default):
MONGO_URI=mongodb://localhost:27017/hyperlocal_jobs
# MongoDB Atlas (cloud) example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hyperlocal_jobs

# ── Authentication ────────────────────────────────
# Change these to long random strings in production
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
SESSION_SECRET=your_session_secret_here

# ── Google OAuth ──────────────────────────────────
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Frontend URL ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
